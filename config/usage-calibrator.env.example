# claude-quota-gauge config -- copy to ~/.claude/usage-calibrator.env and edit.
# All variables are optional; every one has a sane default. This file is loaded
# automatically by the scripts in bin/ (even when invoked from a SessionStart
# hook or launchd, neither of which inherit your shell profile's env vars).

# Path to ccusage, if it's not on PATH and not at ~/.npm-global/bin/ccusage.
# CCUSAGE=/usr/local/bin/ccusage

# Path to your parked-issues file (see the PENDING.md convention in the README).
# Checked in this order if unset: ./PENDING.md (cwd), then ~/.claude/PENDING.md.
# CLAUDE_USAGE_PENDING_FILE=~/notes/PENDING.md

# Which model to track a separate weekly % for, beyond the "all models" total.
# Matches by substring against the model IDs in your local transcripts.
# CLAUDE_USAGE_TRACK_MODEL=opus

# Your account's real weekly reset -- read it off claude.ai/settings/usage
# (shown next to the weekly bar, e.g. "Resets Sat 5:00 AM"). Wrong values here
# silently produce wrong weekly %s. Day is 0=Mon ... 6=Sun.
# CLAUDE_USAGE_RESET_DAY=5
# CLAUDE_USAGE_RESET_HOUR=5
# CLAUDE_USAGE_RESET_TZ=America/New_York

# Desktop-notification threshold for the background watcher (usage-watch.py).
# CLAUDE_USAGE_ALERT_THRESHOLD=85
