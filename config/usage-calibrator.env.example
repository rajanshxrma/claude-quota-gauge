# claude-quota-gauge config -- copy to ~/.claude/usage-calibrator.env and edit.
# All variables are optional; every one has a sane default. This file is loaded
# automatically by the scripts in bin/ (even when invoked from the statusline
# command, a SessionStart hook, or launchd, none of which inherit your shell
# profile's env vars).

# Path to your parked-issues file (see the PENDING.md convention in the README).
# Checked in this order if unset: ./PENDING.md (cwd), then ~/.claude/PENDING.md.
# CLAUDE_USAGE_PENDING_FILE=~/notes/PENDING.md

# Desktop-notification threshold for the background watcher (usage-watch.py).
# CLAUDE_USAGE_ALERT_THRESHOLD=85
