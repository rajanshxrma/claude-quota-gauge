# claude-quota-gauge config -- copy to ~/.claude/claude-quota-gauge.env and edit.
# All variables are optional; every one has a sane default. This file is loaded
# automatically by the scripts in bin/ (even when invoked from the statusline
# command, a SessionStart hook, or launchd, none of which inherit your shell
# profile's env vars).

# Path to your parked-issues file (see the PENDING.md convention in the README).
# Checked in this order if unset: ./PENDING.md (cwd), then ~/.claude/PENDING.md.
# CLAUDE_USAGE_PENDING_FILE=~/notes/PENDING.md

# Which model to show a separate calibrated weekly estimate for, beyond the
# two real rate_limits numbers -- only relevant if your account has its own
# weekly pool for one model (e.g. Fable) that Anthropic's rate_limits field
# doesn't break out. Matches by substring against model IDs in your local
# transcripts. Run /gauge-cali-fable once after setting this.
# CLAUDE_USAGE_TRACK_MODEL=fable

# Desktop-notification threshold for the background watcher (usage-watch.py).
# CLAUDE_USAGE_ALERT_THRESHOLD=85

# macOS-only: flags in the background (via the UserPromptSubmit hook, never
# the visible statusline bar) when the OS light/dark appearance has drifted
# from what a session's UI theme actually resolved against at launch --
# Claude Code checks that once at startup and never again, so a long-open
# session's colors silently go stale with `/config theme=auto` as the only
# fix. Off by default everywhere since it's a platform-specific add-on.
# CLAUDE_USAGE_THEME_WATCH=1
